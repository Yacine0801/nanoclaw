# ============================================================================
# NanoClaw Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Only uncomment what you need.
# ============================================================================

# === Identity ===
ASSISTANT_NAME=Andy                # Agent display name (used in triggers: @Andy)
# ASSISTANT_HAS_OWN_NUMBER=false   # Whether agent has its own WhatsApp number

# === AI Model ===
ANTHROPIC_API_KEY=sk-ant-...       # Anthropic API key (REQUIRED)
# CLAUDE_MODEL=claude-sonnet-4-6   # Claude model for agent containers

# === Cost Control ===
# DAILY_API_LIMIT_USD=20           # Daily API spend limit in USD (default: 20)

# === Container Settings ===
# CONTAINER_PREFIX=nanoclaw         # Container name prefix (unique per instance)
# CONTAINER_IMAGE=nanoclaw-agent:latest  # Docker image for agent containers
# CONTAINER_TIMEOUT=1800000         # Hard timeout per container run in ms (default: 30min)
# CONTAINER_MAX_OUTPUT_SIZE=10485760  # Max stdout/stderr size in bytes (default: 10MB)
# IDLE_TIMEOUT=1800000              # Idle timeout before container cleanup in ms (default: 30min)
# MAX_CONCURRENT_CONTAINERS=5       # Max containers running in parallel (1-20)

# === Network ===
# CREDENTIAL_PROXY_PORT=3001        # Port for credential proxy (unique per instance)
# CREDENTIAL_PROXY_HOST=            # Bind address for credential proxy (auto-detected)

# === Polling Intervals ===
# POLL_INTERVAL=2000                # Channel message poll interval in ms (default: 2s)
# SCHEDULER_POLL_INTERVAL=60000     # Scheduled task poll interval in ms (default: 60s)
# IPC_POLL_INTERVAL=1000            # IPC watcher poll interval in ms (default: 1s)

# === Google Chat Channel ===
# GOOGLE_CHAT_ENABLED=false         # Enable Google Chat channel (true/false)
# GOOGLE_CHAT_AGENT_NAME=nanoclaw   # Agent name used in Firestore message routing
# GOOGLE_APPLICATION_CREDENTIALS=   # Path to Firebase/GCP service account JSON
# GOOGLE_CHAT_BOT_SA=               # Path to Chat Bot service account JSON (for sending)

# === Gmail Channel ===
# GMAIL_WEBHOOK_ENABLED=false       # Enable Gmail webhook signal polling via Firestore
# GMAIL_MCP_DIR=                    # Path to Gmail MCP credentials dir (default: ~/.gmail-mcp)
# GMAIL_DIRECT_SEND_ALLOWLIST=      # Comma-separated email addresses the agent can email directly
# GMAIL_NOTIFY_EMAIL=               # Email address for agent notifications
# GMAIL_CC_EMAIL=                   # CC address on outgoing agent emails

# === Remote Control ===
# REMOTE_CONTROL_PIN=               # PIN for remote control commands (min 4 chars, disabled if empty)

# === Voice Transcription ===
# WHISPER_BIN=whisper-cli           # Path to whisper binary
# WHISPER_MODEL=                    # Path to whisper model file

# === Logging ===
# LOG_LEVEL=info                    # Log level: trace, debug, info, warn, error, fatal

# === Timezone ===
# TZ=                               # Timezone for scheduled tasks (default: system timezone)
